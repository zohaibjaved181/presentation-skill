  "subagent_contract": {
    "contract_version": "style_inspiration_subagent_contract_v1",
    "trigger": "Run after the user query when style or structure is underspecified, when the deck is high-stakes, or when multiple preset routes score closely.",
    "output_schema": {
      "selected_preset": "loadable preset name",
      "primary_source_ids": [
        "source id"
      ],
      "borrowed_descriptor_tags": [
        "descriptor tag"
      ],
      "contact_collection_use_cases_to_open": [
        "overview",
        "data_evidence",
        "decision_sources"
      ],
      "mixing_decisions": [
        {
          "treatment_key": "title | chart | table | figure | dashboard | comparison | decision | references",
          "base_preset": "preset name",
          "borrow_from_preset": "optional preset name",
          "reason": "specific evidence/audience/asset reason"
        }
      ],
      "safety_statement": "Confirm descriptor-only use and synthetic reconstruction."
    },
    "safety_rules": [
      "Do not copy or store third-party PPTX files, screenshots, logos, proprietary text, or distinctive slide geometry.",
      "Use public sources as descriptor memory and reconstruct with generic data/content through local scripts.",
      "If a source is license-unclear, route it to metadata-only or reject it before release.",
      "Record source ids, route id, style seed, treatment mix, and contact-sheet use cases in the design contract."
    ],
    "scout_loop": [
      "Rank preset routes from prompt, audience, evidence objects, and asset burden.",
      "Open the primary preset contact-sheet collection first, then compare one or two secondary preset collections.",
      "Borrow treatment-specific ideas only when they fit the primary preset's metric profile and renderer pools.",
      "Return deterministic choices that the main agent can write into design_brief.json and outline.json."
    ]
  }
}
