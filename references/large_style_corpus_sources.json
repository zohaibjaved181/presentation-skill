{
  "manifest_version": "large_style_corpus_source_manifest_v1",
  "checked_date": "2026-06-22",
  "purpose": "Descriptor-only discovery plan for a large public/open-source deck catalog. The collector records URLs and inferred style metadata only; it does not download or bundle raw third-party decks, screenshots, logos, slide text, or proprietary geometry.",
  "policy": {
    "storage_rule": "descriptor_only_no_raw_decks",
    "allowed_record_types": [
      "public repository URL",
      "deck-like file path",
      "repository metadata exposed by provider search",
      "inferred style descriptors from names, paths, query route, and extension",
      "balanced catalog summaries",
      "synthetic reconstruction prompts"
    ],
    "forbidden_materials": [
      "raw third-party PPTX files",
      "raw screenshots from third-party decks",
      "copied slide body text",
      "logos or brand marks copied from source decks",
      "distinctive copied slide geometry",
      "private or confidential data"
    ],
    "rights_posture": "metadata_only_public_url_license_unverified",
    "agent_use_rule": "Use catalog records as inspiration pointers and descriptor evidence. Do not download, embed, screenshot, copy, or reproduce source decks unless a later human-reviewed source route explicitly clears the asset/license."
  },
  "providers": [
    {
      "provider": "github_code_search",
      "tool": "gh search code",
      "official_docs": "https://cli.github.com/manual/gh_search_code",
      "search_scope": "public GitHub code search metadata",
      "record_fields": [
        "repository.nameWithOwner",
        "repository.url",
        "repository.isFork",
        "repository.isPrivate",
        "path",
        "url"
      ],
      "notes": [
        "The GitHub CLI manual documents --extension, --filename, --json, --limit, and JSON fields path, repository, sha, textMatches, and url.",
        "GitHub code search results are metadata pointers for this skill; raw file content is not collected."
      ]
    },
    {
      "provider": "github_repo_search",
      "tool": "gh search repos",
      "official_docs": "https://cli.github.com/manual/gh_search_repos",
      "search_scope": "public GitHub repository metadata for slide systems and AI deck generators",
      "record_fields": [
        "fullName",
        "url",
        "description",
        "license",
        "stargazersCount",
        "updatedAt",
        "topics"
      ],
      "notes": [
        "Repository search is used only for ecosystem/source-system context, not for claiming a repository contains one deck."
      ]
    }
  ],
  "deck_targets": {
    "minimum_unique_deck_records": 2000,
    "minimum_records_per_style_family": 10,
    "stretch_records_per_style_family": 100,
    "preferred_unique_repository_floor": 400,
    "preferred_ai_agent_signal_floor": 25
  },
  "style_families": [
    "lab-report",
    "forest-research",
    "paper-journal",
    "executive-clinical",
    "data-heavy-boardroom",
    "charcoal-safety",
    "bold-startup-narrative",
    "sunset-investor",
    "editorial-minimal",
    "arctic-minimal",
    "midnight-neon",
    "lavender-ops",
    "warm-terracotta"
  ],
  "overlap_policy": {
    "dedupe_key": "provider + repository + normalized path",
    "overlap_key_fields": [
      "deck_system",
      "primary_style_family",
      "deck_format",
      "path_shape"
    ],
    "default_max_per_repository": 8,
    "default_max_per_owner": 40,
    "default_max_per_overlap_key": 80,
    "replacement_rule": "Prefer underrepresented style families, AI-agent-created or AI-tooling signals, diverse deck systems, and different repository owners before filling remaining slots from common slide/pdf buckets."
  },
  "query_defaults": {
    "provider": "github_code_search",
    "limit": 90,
    "json_fields": [
      "repository",
      "path",
      "url"
    ],
    "include_forks": false,
    "sleep_ms": 250
  },
